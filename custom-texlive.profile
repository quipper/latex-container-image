# The full scheme takes too long to install, so install only the collections we need.
# Note that the medium scheme is still missing a lot and would not be as aligned to our needs.
collection-basic 1
collection-latex 1
collection-latexrecommended 1
collection-latexextra 1
collection-metapost 1
collection-xetex 1
collection-luatex 1
collection-langenglish 1
collection-langjapanese 1
collection-mathscience 1
collection-fontutils 1
collection-fontsrecommended 1
collection-fontsextra 1
collection-binextra 1

# In the container image docs and sources are not needed.
tlpdbopt_install_docfiles 0
tlpdbopt_install_srcfiles 0
